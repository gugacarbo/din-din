# Variáveis de ambiente injetadas no runtime do Worker durante o `wrangler dev`.
# O binding D1 (DB) é configurado em wrangler.jsonc, não aqui.
# Use este arquivo apenas para segredos/secrets que precisam estar disponíveis
# no código do Worker em desenvolvimento local.

BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
