{
  "name": "din-din",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build && tsx scripts/generate-service-worker.ts",
    "preview": "vite preview",
    "test": "pnpm run test:unit && pnpm run test:ui && pnpm run test:workers",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "types:wrangler": "wrangler types --include-runtime --include-env src/worker-configuration.d.ts",
    "types:wrangler:check": "wrangler types --include-runtime --include-env src/worker-configuration.d.ts --check",
    "types:wrangler:negative": "node scripts/check-wrangler-types-negative.mjs",
    "cf-typegen": "pnpm run types:wrangler",
    "format": "biome check --write",
    "format:md": "pnpx prettier --write \"**/*.{md,mdx}\" --log-level=warn --no-error-on-unmatched-pattern --cache",
    "lint": "biome lint",
    "check": "biome check",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "lint-staged": "lint-staged",
    "test-staged": "test-staged",
    "release:verify": "pnpm run types:wrangler:check && pnpm run types:wrangler:negative && pnpm run check && pnpm run typecheck && pnpm test && pnpm run build",
    "deploy": "pnpm run build && pnpm run db:migrate:remote && wrangler deploy",
    "db:create": "wrangler d1 create din-din",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply din-din --local",
    "db:migrate:remote": "wrangler d1 migrations apply din-din --remote",
    "db:migrate": "pnpm run db:migrate:local",
    "verify:migration-rollback": "node scripts/verify-migration-rollback.mjs",
    "db:studio": "drizzle-kit studio",
    "admin:invite": "tsx scripts/create-admin-invite.ts",
    "prepare": "husky",
    "docs-check": "python3 ./scripts/docs-check"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@cloudflare/vite-plugin": "^1.46.0",
    "@hookform/resolvers": "^5.4.0",
    "@t3-oss/env-core": "^0.13.11",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.168.23",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.25.0",
    "radix-ui": "^1.6.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-hook-form": "^7.82.0",
    "recharts": "3.10.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@cloudflare/vitest-pool-workers": "0.18.7",
    "@cloudflare/workers-types": "^5.20260721.1",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.167.21",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "test-staged": "^1.1.11",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "workbox-build": "^7.4.1",
    "wrangler": "^4.113.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
