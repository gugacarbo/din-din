#!/usr/bin/env sh

# Bloqueia push cujo destino no remoto é branch de produção (main/master).
# Cobre: git push origin main, git push origin feature:main, git push origin :main, etc.
# Não cobre: git push --no-verify (use branch protection no GitHub).

blocked=0
refspecs_file=$(mktemp)

echo "\033[0;35mRunning pre-push checks...\033[0m"

PROTECTED_BRANCHES="main master staging"

while read -r local_ref local_sha remote_ref remote_sha; do
  printf '%s %s %s %s\n' "$local_ref" "$local_sha" "$remote_ref" "$remote_sha" >> "$refspecs_file"

  case "$remote_ref" in
    refs/heads/*)
      remote_branch="${remote_ref#refs/heads/}"
      remote_branch_lower=$(printf '%s' "$remote_branch" | tr '[:upper:]' '[:lower:]')
      case "$remote_branch_lower" in
        $PROTECTED_BRANCHES)
          blocked=1
          printf '\n'
          printf '\033[1;31m✖ Push para a branch %s está bloqueado\033[0m\n' "$remote_branch"
          if [ -n "$local_ref" ]; then
            local_branch="${local_ref#refs/heads/}"
            printf '\033[0m   Refspec: %s → %s\033[0m\n' "$local_branch" "$remote_branch"
          elif [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
            printf '\033[0m   Refspec: (delete) → %s\033[0m\n' "$remote_branch"
          fi
          printf '\033[1;33m↳ Faça push para staging (ex.: git push origin HEAD:staging).\033[0m\n'
          #! printf '\033[0;90m   --no-verify ignora este hook; proteja main no remoto também.\033[0m\n'
          printf '\n'
          ;;
      esac
      ;;
  esac
done

if [ "$blocked" -eq 1 ]; then
  rm -f "$refspecs_file"
  exit 1
fi


CHANGELOG_PUSH_REFSPECS="$(cat "$refspecs_file")" pnpm changelog:validate-pre-push
changelog_exit=$?

if [ "$changelog_exit" -ne 0 ]; then
  rm -f "$refspecs_file"
  exit "$changelog_exit"
fi

pnpm knip:prod

pnpm biome check
pnpm build

should_typecheck=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base=$(
      git merge-base "$local_sha" origin/main 2>/dev/null ||
        git merge-base "$local_sha" origin/master 2>/dev/null ||
        true
    )
    if [ -z "$base" ]; then
      should_typecheck=1
      break
    fi
    if git diff --name-only "$base" "$local_sha" -- '*.ts' '*.tsx' | grep -q .; then
      should_typecheck=1
      break
    fi
    continue
  fi

  if git diff --name-only "$remote_sha" "$local_sha" -- '*.ts' '*.tsx' | grep -q .; then
    should_typecheck=1
    break
  fi
done < "$refspecs_file"

rm -f "$refspecs_file"

if [ "$should_typecheck" -eq 1 ]; then
  pnpm typecheck
else
  printf '\033[0;90mSkipping typecheck (no TypeScript changes in push).\033[0m\n'
fi

pnpm test
