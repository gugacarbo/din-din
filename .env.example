# Credenciais usadas pelo drizzle-kit (driver d1-http) para gerar/aplicar
# migrations remotas via a API HTTP do Cloudflare D1.
# Crie um token em: https://dash.cloudflare.com/profile/api-tokens
# Use o template "Edit Cloudflare Workers" ou crie um token com permissão
# D1 Edit + Account Read.

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
